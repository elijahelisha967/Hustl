{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/users/onboarding", "dest": "/api/users/onboarding.js" },
    { "src": "/api/signup", "dest": "/api/signup.js" },
    { "src": "/api/login", "dest": "/api/login.js" },
    { "src": "/api/profile", "dest": "/api/profile.js" },
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/(.*\\.html)", "dest": "/public/$1" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}