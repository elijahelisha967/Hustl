{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/onboarding", "dest": "/api/onboarding.js" },
    { "src": "/api/signup", "dest": "/api/signup.js" },
    { "src": "/api/login", "dest": "/api/login.js" },
    { "src": "/api/profile", "dest": "/api/profile.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}